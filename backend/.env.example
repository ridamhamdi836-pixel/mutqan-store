APP_ENV=production
APP_NAME=mutqan-api
API_PREFIX=/api/v1

# Easypanel may inject postgres:// — the app normalizes to postgresql+psycopg://
DATABASE_URL=postgresql+psycopg://mutqan:mutqan@mutqan_database:5432/mutqan
CORS_ORIGINS=https://mutqan.online
SECRET_KEY=replace-with-long-random-secret-min-32-chars
ADMIN_API_KEY=replace-with-admin-api-key

# Admin dashboard (hosted on Next.js frontend — set these on Easypanel frontend service)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=replace-with-long-random-secret-min-32-chars

# MaxMind GeoIP Insights (KSA + VPN detection — set on frontend service too)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Google Sheets: handled by Next.js frontend only (GOOGLE_SHEETS_WEBHOOK_URL on frontend service)

META_PIXEL_ID=
META_ACCESS_TOKEN=
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
SNAPCHAT_PIXEL_ID=
SNAPCHAT_ACCESS_TOKEN=
