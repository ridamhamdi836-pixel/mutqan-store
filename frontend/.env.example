NEXT_PUBLIC_SITE_URL=https://mutqan.online
NEXT_PUBLIC_API_URL=https://api.mutqan.online

# PostgreSQL Database (same database used by the backend)
DATABASE_URL=postgresql://mutqan:mutqan@mutqan_database:5432/mutqan

NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

NEXT_PUBLIC_WHATSAPP_NUMBER=212717783042
NEXT_PUBLIC_SUPPORT_EMAIL=support@mutqan.online

# MaxMind GeoIP2 - IP verification & VPN/proxy detection
# Sign up at https://www.maxmind.com/en/geolite2/signup
# Use Insights endpoint for VPN/proxy detection (paid), or Country for basic geo (free GeoLite2)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Comma-separated phone numbers that bypass IP verification (for testing in prod)
WHITELISTED_PHONES=0512345678

# Google Sheets webhook (Apps Script — mutqan-apps-script.js)
# REQUIRED on FRONTEND — checkout posts to /api/orders on Next.js, not FastAPI
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Legacy alias (optional — used if GOOGLE_SHEETS_WEBHOOK_URL is empty)
CODNETWORK_WEBHOOK_URL=
