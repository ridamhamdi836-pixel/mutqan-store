NEXT_PUBLIC_SITE_URL=https://mutqan.online
NEXT_PUBLIC_API_URL=https://api.mutqan.online

DATABASE_URL=postgresql://mutqan:mutqan@mutqan_database:5432/mutqan

# Browser pixels — FRONTEND service only (Easypanel). Redeploy after change.
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# Prefer SNAPCHAT (not SNAP_PIXEL alone unless both set)
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=
NEXT_PUBLIC_SNAP_PIXEL_ID=
NEXT_PUBLIC_ENABLE_PIXELS=true
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Aliases read at runtime on frontend (optional duplicates of above)
META_PIXEL_ID=
TIKTOK_PIXEL_CODE=
SNAPCHAT_PIXEL_ID=

NEXT_PUBLIC_WHATSAPP_NUMBER=212717783042
NEXT_PUBLIC_SUPPORT_EMAIL=support@mutqan.online

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Admin dashboard — https://mutqan.online/admin (set on FRONTEND service in Easypanel)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=generate-a-long-random-string-min-32-chars
# If credentials are only on backend, set API URL + same ADMIN_SESSION_SECRET here:
# NEXT_PUBLIC_API_URL=https://api.mutqan.online
# ADMIN_BACKEND_URL=https://api.mutqan.online

WHITELISTED_PHONES=0512345678

# Google Sheets (Apps Script web app URL — must end with /exec)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Optional: protect GET /api/debug/google-sheets (?key=YOUR_SECRET)
DEBUG_SECRET=
