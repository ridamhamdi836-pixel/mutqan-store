# MaxMind GeoIP2 - IP verification & VPN/proxy detection
# Sign up at https://www.maxmind.com/en/geolite2/signup
# Use Insights endpoint for VPN/proxy detection (paid), or Country for basic geo (free GeoLite2)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Comma-separated phone numbers that bypass IP verification (for testing in prod)
WHITELISTED_PHONES=0512345678

# CodNetwork Google Sheet Integration
# Deploy the Apps Script from codnetwork-apps-script.js as a web app and paste the URL here
CODNETWORK_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
